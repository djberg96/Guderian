<% content_for :title, "Guderian Board" %>
<% content_for :head do %>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const shell = document.querySelector("[data-board-shell]");
      const zoomValue = document.querySelector("[data-zoom-value]");

      if (!shell || !zoomValue) return;

      const applyZoom = (zoom) => {
        shell.style.setProperty("--board-zoom", zoom);
        zoomValue.textContent = `${Math.round(zoom * 100)}%`;
      };

      applyZoom(1.5);

      document.querySelectorAll("[data-zoom-action]").forEach((button) => {
        button.addEventListener("click", () => {
          const action = button.dataset.zoomAction;
          const currentZoom = Number.parseFloat(shell.style.getPropertyValue("--board-zoom") || "1");

          if (action === "in") applyZoom(Math.min(2.5, currentZoom + 0.2));
          if (action === "out") applyZoom(Math.max(0.4, currentZoom - 0.2));
          if (action === "reset") applyZoom(1);
        });
      });
    });
  </script>
<% end %>

<main class="board-page">
  <details class="board-hero">
    <summary class="board-hero-toggle">Show Scenario Header</summary>
    <div class="board-hero-content">
      <p class="eyebrow">Smolensk 1941</p>
      <h1>Guderian</h1>
      <p class="board-summary">
        The database-backed opening map. Germans are intended to be the default human side; Soviet forces will become the AI side as we layer counters, turns, and rules onto the board.
      </p>
      <dl class="board-stats">
        <div>
          <dt>Columns</dt>
          <dd><%= Map::HexGridBuilder::COLUMN_COUNT %></dd>
        </div>
        <div>
          <dt>Rows</dt>
          <dd><%= Map::HexGridBuilder::ROW_COUNT %></dd>
        </div>
        <div>
          <dt>Total hexes</dt>
          <dd><%= @hexes.size %></dd>
        </div>
        <div>
          <dt>Human Side</dt>
          <dd><%= Scenarios::DefaultForcesBuilder.side_assignments[:human].titleize %></dd>
        </div>
        <div>
          <dt>AI Side</dt>
          <dd><%= Scenarios::DefaultForcesBuilder.side_assignments[:ai].titleize %></dd>
        </div>
      </dl>
    </div>
  </details>

  <section class="board-shell">
    <div class="board-controls">
      <div class="board-zoom-controls" aria-label="Map zoom controls">
        <button type="button" class="zoom-button" data-zoom-action="out">-</button>
        <button type="button" class="zoom-button" data-zoom-action="reset">100%</button>
        <button type="button" class="zoom-button" data-zoom-action="in">+</button>
        <span class="zoom-readout" data-zoom-value>150%</span>
      </div>
    </div>

    <div class="board-viewport" data-board-shell>
      <svg
        class="hex-board"
        viewBox="0 0 <%= @board_metrics[:width] %> <%= @board_metrics[:height] %>"
        role="img"
        aria-label="Guderian hex map"
      >
        <% @hexes.each do |hex| %>
          <g class="hex-cell terrain-<%= hex.terrain_type %>">
            <image
              href="<%= asset_href(hex.terrain_asset_path) %>"
              x="<%= hex.svg_x %>"
              y="<%= hex.svg_y %>"
              width="<%= Map::HexGridBuilder::HEX_WIDTH %>"
              height="<%= Map::HexGridBuilder::HEX_HEIGHT %>"
              preserveAspectRatio="none"
            />
            <% if full_lake_hex?(hex) %>
              <polygon class="lake-fill" points="<%= flat_top_hex_points(hex) %>" />
            <% end %>
            <polygon points="<%= flat_top_hex_points(hex) %>" />
            <% if hex.road_exits.any? %>
              <path
                class="route-overlay road-overlay"
                d="<%= overlay_path_data(hex, hex.road_exits, lateral_offset: route_lateral_offset(hex, :road), route_style: :road) %>"
                transform="<%= hex_overlay_transform(hex) %>"
              />
            <% end %>
          <% if hex.railroad_exits.any? %>
            <path
              class="route-overlay railroad-bed"
              d="<%= overlay_path_data(hex, hex.railroad_exits, lateral_offset: route_lateral_offset(hex, :railroad), route_style: :railroad) %>"
              transform="<%= hex_overlay_transform(hex) %>"
            />
            <path
              class="route-overlay railroad-rail"
              d="<%= overlay_path_data(hex, hex.railroad_exits, lateral_offset: route_lateral_offset(hex, :railroad), route_style: :railroad) %>"
              transform="<%= hex_overlay_transform(hex) %>"
            />
              <path
                class="route-overlay railroad-ties"
                d="<%= railroad_tie_path_data(hex, hex.railroad_exits, lateral_offset: route_lateral_offset(hex, :railroad)) %>"
                transform="<%= hex_overlay_transform(hex) %>"
              />
          <% end %>
            <text
              x="<%= hex.svg_x + Map::HexGridBuilder::HEX_WIDTH / 2.0 %>"
              y="<%= hex.svg_y + (Map::HexGridBuilder::HEX_HEIGHT * 0.2) %>"
            >
              <%= hex.label %>
            </text>
          </g>
        <% end %>

        <% river_paths = river_path_data(@hexes) %>
        <% if river_paths.present? %>
          <path class="hexside-overlay river-edge" d="<%= river_paths %>" />
          <path class="hexside-overlay river-edge river-edge-variation" d="<%= river_paths %>" />
          <path class="hexside-overlay river-edge river-edge-inner" d="<%= river_paths %>" />
        <% end %>

        <% lake_paths = lake_path_data(@hexes) %>
        <% if lake_paths.present? %>
          <path class="hexside-overlay lake-edge-bleed" d="<%= lake_paths %>" />
          <path class="hexside-overlay lake-edge" d="<%= lake_paths %>" />
          <path class="hexside-overlay lake-edge-inner" d="<%= lake_paths %>" />
        <% end %>
      </svg>
    </div>
  </section>
</main>
